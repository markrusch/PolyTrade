{
  "name": "polytrade",
  "version": "1.0.0",
  "description": "Enterprise-grade algorithmic trading platform for Polymarket, Deribit, and Binance",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "vite",
    "server": "tsx watch server.ts",
    "dev:api": "tsx watch server.ts",
    "dev:backend-test": "tsx watch src/examples/test-binance.ts",
    "dev:binance": "tsx src/examples/test-binance.ts",
    "dev:deribit": "tsx src/examples/test-deribit.ts",
    "dev:polymarket": "tsx src/examples/test-polymarket.ts",
    "dev:integration": "tsx src/examples/test-integration.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "db:migrate": "tsx src/db/migrate_v1_to_v2.ts",
    "db:rollback": "tsx src/db/rollback_v2_to_v1.ts",
    "db:validate": "tsx src/db/validate_migration.ts",
    "db:test-migration": "tsx src/db/test_migration.ts"
  },
  "keywords": [
    "polymarket",
    "deribit",
    "binance",
    "trading",
    "algorithmic-trading",
    "options",
    "prediction-markets"
  ],
  "author": "PolyTrade Team",
  "license": "MIT",
  "dependencies": {
    "@polymarket/clob-client": "^5.1.2",
    "@safe-global/protocol-kit": "^4.1.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "duckdb-async": "^1.4.2",
    "ethers": "^6.11.0",
    "express": "^4.22.1",
    "p-limit": "^7.2.0",
    "winston": "^3.11.0",
    "ws": "^8.15.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.6",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
